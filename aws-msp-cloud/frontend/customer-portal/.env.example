# Customer Portal Environment Variables

# Optional: Provide your own API keys for better performance
# If not provided, the backend will use demo keys

# OpenAI API Key (for embeddings)
# Get from: https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=

# OpenRouter API Key (for chat)
# Get from: https://openrouter.ai/keys
VITE_OPENROUTER_API_KEY=

# Backend API URL (default: proxied through Vite)
VITE_API_URL=http://localhost:8000
